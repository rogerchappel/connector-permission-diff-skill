{
  "name": "connector-permission-diff-skill",
  "version": "0.1.0",
  "description": "Local-first connector permission diff skill for dry-run agent action reviews.",
  "type": "module",
  "bin": {
    "connector-permission-diff": "./src/cli.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/cli.js && node --check src/index.js",
    "smoke": "node src/cli.js --manifest fixtures/connector-manifest.json --policy fixtures/approval-policy.json --format markdown",
    "validate": "bash scripts/validate.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run validate && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "connector",
    "permissions",
    "dry-run",
    "approval"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/connector-permission-diff-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/connector-permission-diff-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/connector-permission-diff-skill#readme",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src",
    "docs",
    "fixtures",
    "examples",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ]
}
